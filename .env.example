# CityBus Environment Variables Template
# Copy this file to .env and fill in your details

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_web_id

# Google Maps API Configuration
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Real transit data
# Use "tgsrtc-gtfs" to load official TGSRTC static GTFS files instead of bundled seed routes/stops.
# Download access starts from: https://tgsrtc.telangana.gov.in/open-data
# Put unzipped GTFS files in public/gtfs or point this to a hosted folder containing routes.txt, stops.txt, trips.txt, stop_times.txt.
VITE_TRANSIT_DATA_SOURCE=seed
VITE_TGSRTC_GTFS_BASE_URL=/gtfs

# Optional legacy live-status proxy discovered from old public TSRTC tracking projects.
# Do not point browser clients directly at the legacy HTTP host; use your own permitted server proxy if you have authorization.
VITE_TSRTC_LEGACY_BATS_PROXY_URL=
